<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Added the entity VisitorLog.
    -->
    <changeSet id="20250918220000-1" author="zoran">
        <createTable tableName="visitor_log">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ip_address" type="varchar(255)"/>
            <column name="page_visited" type="varchar(255)"/>
            <column name="user_agent" type="varchar(512)"/>
            <column name="visit_timestamp" type="timestamp"/>
        </createTable>
    </changeSet>
</databaseChangeLog>